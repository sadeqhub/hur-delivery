  "voiceover_script": {
    "language": "Arabic",
    "style": "Friendly, professional, motivating",
    "scenes": [
      {
        "scene": 1,
        "text": "مرحباً بك في حر - منصة التوصيل الذكية"
      },
      {
        "scene": 2,
        "text": "كنت تبحث عن طلبات توصيل؟ تريد زيادة دخلك بسهولة؟"
      },
      {
        "scene": 3,
        "text": "مع تطبيق حر، كل شيء أصبح سهلاً. استقبل طلبات توصيل مباشرة على هاتفك"
      },
      {
        "scene": 4,
        "text": "استقبل إشعارات فورية بطلبات جديدة - اقبل أو ارفض - أنت تتحكم"
      },
      {
        "scene": 5,
        "text": "ملاحة مباشرة مع خرائط تفاعلية - تتبع دقيق - اعرف أين أنت دائماً"
      },
      {
        "scene": 6,
        "text": "أرباح فورية - تُضاف تلقائياً لمحفظتك - تتبع كل رحلة وأرباحك بسهولة"
      },
      {
        "scene": 7,
        "text": "يعمل حتى بدون إنترنت - تتبع إحصائياتك وأرباحك - محفظة رقمية آمنة"
      },
      {
        "scene": 8,
        "text": "انضم لآلاف السائقين الناجحين - ابدأ رحلتك مع حر اليوم"
      },
      {
        "scene": 9,
        "text": "حمّل تطبيق حر الآن - ابدأ كسب المال اليوم - حر - توصيل سريع، أرباح مباشرة"
      }
    ]
