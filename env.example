# ============================================================================
# Hur Delivery App Environment Configuration
# ============================================================================
# SECURITY NOTICE: This file contains sensitive credentials
# - NEVER commit this file to version control (it's in .gitignore)
# - Use strong, unique values for all secrets
# - Rotate keys regularly (every 90 days minimum)
# - Use different values for development, staging, and production
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase Configuration
# ----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# CRITICAL: Service Role Key - NEVER expose client-side
# This key bypasses Row Level Security (RLS) - only use server-side
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------------------------------------------
# Mapbox Configuration
# ----------------------------------------------------------------------------
# Get from: https://account.mapbox.com/access-tokens/
# Public token (safe for client-side use)
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token-here

# Secret token (server-side only, for API calls)
MAPBOX_SECRET_TOKEN=sk.your-mapbox-secret-token-here
# iOS native builds: copy ios/Flutter/Secrets.xcconfig.example to
# ios/Flutter/Secrets.xcconfig and set MAPBOX_ACCESS_TOKEN there.

# ----------------------------------------------------------------------------
# Payment Gateway (Wayl)
# ----------------------------------------------------------------------------
# SECURITY: These must be set in Supabase Edge Functions secrets
# Never hardcode in source code
# Set via: supabase secrets set WAYL_MERCHANT_TOKEN=your-token
WAYL_MERCHANT_TOKEN=your-wayl-merchant-token-here
WAYL_SECRET=your-wayl-webhook-secret-here

# ----------------------------------------------------------------------------
# WhatsApp Integration (Wasso)
# ----------------------------------------------------------------------------
# SECURITY: Set in Supabase Edge Functions secrets
# Set via: supabase secrets set WASSO_API_KEY=your-key
WASSO_API_KEY=your-wasso-api-key-here

# ----------------------------------------------------------------------------
# OTP Service (OTPIQ)
# ----------------------------------------------------------------------------
# SECURITY: Set in Supabase Edge Functions secrets
# Set via: supabase secrets set OTPIQ_API_KEY=your-key
OTPIQ_API_KEY=your-otpiq-api-key-here

# ----------------------------------------------------------------------------
# AI Services (OpenAI)
# ----------------------------------------------------------------------------
# For ID verification and voice transcription
# SECURITY: Set in Supabase Edge Functions secrets
# Set via: supabase secrets set OPENAI_API_KEY=your-key
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_ASSISTANT_ID=asst_your_assistant_id_here

# ----------------------------------------------------------------------------
# Admin Panel Authentication
# ----------------------------------------------------------------------------
# SECURITY: Set in Supabase Edge Functions secrets
# Username should be alphanumeric only (no special characters)
ADMIN_LOGIN_USERNAME=admin
# Option 1: Plain password (will be hashed)
ADMIN_LOGIN_PASSWORD=your-strong-password-here
# Option 2: Pre-hashed password (SHA-256)
# ADMIN_LOGIN_PASSWORD_HASH=your-sha256-hash-here
# Display name for admin user
ADMIN_DISPLAY_NAME=System Administrator

# ----------------------------------------------------------------------------
# Firebase Configuration
# ----------------------------------------------------------------------------
# For push notifications (FCM)
FIREBASE_PROJECT_ID=your-firebase-project-id

# ----------------------------------------------------------------------------
# Daily Summary Configuration
# ----------------------------------------------------------------------------
# Phone numbers to send daily summary reports to (WhatsApp)
# Format: Comma-separated phone numbers (Iraq country code + phone number, no + sign)
# Example: 9647814104097,97807681770,97823188962
# Set via: supabase secrets set ADMIN_PHONES=9647814104097,97807681770,97823188962
# Note: ADMIN_PHONE (singular) is also supported for backward compatibility
ADMIN_PHONES=9647814104097,97807681770,97823188962
ADMIN_PHONE=964XXXXXXXXX

# ----------------------------------------------------------------------------
# Application Configuration
# ----------------------------------------------------------------------------
# Environment: development, staging, production
ENVIRONMENT=development

# API Base URL
BASE_URL=https://api.hur.delivery

# ----------------------------------------------------------------------------
# Security Best Practices
# ----------------------------------------------------------------------------
# 1. Key Rotation:
#    - Rotate all API keys every 90 days
#    - Immediately rotate if a key is compromised
#    - Keep old keys active for 24 hours during rotation
#
# 2. Access Control:
#    - Limit API key permissions to minimum required
#    - Use separate keys for dev/staging/production
#    - Never share keys via email or chat
#
# 3. Monitoring:
#    - Enable API usage alerts
#    - Monitor for unusual patterns
#    - Set up rate limit notifications
#
# 4. Storage:
#    - Use environment variables or secrets manager
#    - Never commit .env to git
#    - Encrypt at rest when possible
#
# 5. Supabase Edge Functions:
#    - Set secrets via CLI: supabase secrets set KEY=value
#    - List secrets: supabase secrets list
#    - Never hardcode secrets in function code
# ============================================================================
